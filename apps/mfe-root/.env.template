# ============================================================================
# CONFIGURAÇÃO DE MICROFRONTENDS - MFE ROOT
# ============================================================================
# 
# Este arquivo define todas as configurações necessárias para registrar e
# carregar Microfrontends (MFEs) no root aplicação.
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local (não commitar!)
# 2. Preencha as variáveis com os valores corretos para seu ambiente
# 3. Adicione novos MFEs seguindo o padrão documentado abaixo
#
# PADRÃO DE VARIÁVEIS:
# - VITE_MFE_[NOME]_URL: URL completa da aplicação em desenvolvimento
# - VITE_MFE_[NOME]_PORT: Porta local de desenvolvimento (para ref. apenas)
# - VITE_MFE_[NOME]_PATH: Rota base no root onde o MFE é ativado
# - VITE_MFE_[NOME]_DOM_ELEMENT: ID do elemento DOM onde MFE será montado
# - VITE_MFE_[NOMBRE]_ENABLED: true/false para habilitar/desabilitar
#
# ============================================================================

# MFE SHELL (Sempre obrigatório - gerencia estado global)
# ============================================================================
VITE_MFE_SHELL_URL=http://localhost:5174
VITE_MFE_SHELL_PORT=5174
VITE_MFE_SHELL_PATH=/
VITE_MFE_SHELL_DOM_ELEMENT=mfe-shell
VITE_MFE_SHELL_ENABLED=true
VITE_MFE_SHELL_ALWAYS_ACTIVE=true


# MFE CALL CENTER (Nova interface - padrão)
# ============================================================================
VITE_MFE_CALL_CENTER_URL=http://localhost:5175
VITE_MFE_CALL_CENTER_PORT=5175
VITE_MFE_CALL_CENTER_PATH=/call-center
VITE_MFE_CALL_CENTER_DOM_ELEMENT=mfe-call-center
VITE_MFE_CALL_CENTER_ENABLED=true


# MFE CALL CENTER LEGACY (Interface legada)
# ============================================================================
VITE_MFE_CALL_CENTER_LEGACY_URL=http://localhost:5176
VITE_MFE_CALL_CENTER_LEGACY_PORT=5176
VITE_MFE_CALL_CENTER_LEGACY_PATH=/legacy
VITE_MFE_CALL_CENTER_LEGACY_DOM_ELEMENT=mfe-call-center-legacy
VITE_MFE_CALL_CENTER_LEGACY_ENABLED=true


# ============================================================================
# EXEMPLOS DE COMO ADICIONAR NOVO MFE
# ============================================================================

# Se você quer ADICIONAR um novo MFE localmente:
#
# 1. Clone o repositório do MFE em paralelo ao root:
#    $ git clone https://github.com/seu-org/mfe-novo-modulo.git
#
# 2. Execute o dev server do novo MFE (será executado na porta configurada)
#    $ cd mfe-novo-modulo && npm run dev
#
# 3. Adicione as variáveis abaixo ao .env.local DESTE ARQUIVO (mfe-root):
#
#    VITE_MFE_NOVO_MODULO_URL=http://localhost:5177
#    VITE_MFE_NOVO_MODULO_PORT=5177
#    VITE_MFE_NOVO_MODULO_PATH=/novo-modulo
#    VITE_MFE_NOVO_MODULO_DOM_ELEMENT=mfe-novo-modulo
#    VITE_MFE_NOVO_MODULO_ENABLED=true
#
# 4. Adicione a div container no App.tsx:
#    <div id="mfe-novo-modulo"></div>
#
# 5. O novo MFE será automaticamente registrado e carregado na rota /novo-modulo
#
# NOMES RECOMENDADOS (snake_case → SHOUT_CASE):
# - mfe-resources        → VITE_MFE_RESOURCES_*
# - mfe-analytics        → VITE_MFE_ANALYTICS_*
# - mfe-reporting        → VITE_MFE_REPORTING_*
# - mfe-user-management  → VITE_MFE_USER_MANAGEMENT_*


# ============================================================================
# CONFIGURAÇÕES GERAIS
# ============================================================================

# Modo de produção (se true, carrega MFEs via SystemJS/importmap)
VITE_ENV=development

# URL base para carregamento em produção (descomente quando deploy)
# VITE_MFE_REGISTRY_URL=https://app.seudominio.com/mfe-registry

# Habilitar logs de debug no carregamento de MFEs
VITE_DEBUG_MFE_LOADING=false

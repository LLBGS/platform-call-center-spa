# ============================================================================
# CONFIGURACAO DO UNLEASH - MFE SHELL
# ============================================================================
#
# INSTRUCOES:
# 1. Copie este arquivo para .env.local (nao commitar)
# 2. Preencha URL e token frontend
# 3. Reinicie o servidor do mfe-shell
#
# OBS:
# - Chaves novas do Unleash podem levar ate 1 minuto para ativar
# - Se URL/token nao forem informados, o shell usa fallback local
# ============================================================================

# Endpoint frontend API do Unleash
VITE_UNLEASH_FRONTEND_API_URL=http://localhost:3001/api/frontend/

# Chave frontend (nao usar chave server-side no browser)
VITE_UNLEASH_FRONTEND_TOKEN=default:development.unleash-insecure-frontend-api-token

# Nome da aplicacao enviado ao Unleash
VITE_UNLEASH_APP_NAME=mfe-shell

# Timeout para bootstrap inicial de flags (ms)
VITE_UNLEASH_TIMEOUT_MS=1000

# Intervalo de refresh automatico das flags (s)
VITE_UNLEASH_REFRESH_INTERVAL=15
